# === Version / logs ===
VMO_VERSION=latest
VMO_LOG_LEVEL=DEBUG
VMO_EVENT_BUS=logging

# === Admin token for POST /admin/reload ===
VMO_ADMIN_TOKEN=change-me-in-production

# === AudioSocket ===
VMO_AUDIOSOCKET_HOST=0.0.0.0
VMO_AUDIOSOCKET_PORT=8090
VMO_AUDIOSOCKET_ADVERTISE_HOST=vmo_pipecat

# === Asterisk credentials / networking ===
AST1_ARI_USERNAME=vmo
AST1_ARI_PASSWORD=
HOST_IP_NIC=
LOCAL_NET=
RTP_START=10000
RTP_END=10020

# === Asterisk extensions test password ===
PASS_EXTENSIONS_TEST=

# === Provider API keys ===
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
AWS_KEY=
AWS_SECRET=

# === ElevenLabs TTS voice ===
EL_VOICE_ID=

# === ElevenLabs full-agent ===
EL_AGENT_ID=
