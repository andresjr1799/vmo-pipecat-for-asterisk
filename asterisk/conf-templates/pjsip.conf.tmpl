[general]
type = global
user_agent = empatIA

[transport-udp]
type = transport
protocol = udp
bind = 0.0.0.0:${ASTERISK_PORT}
external_media_address = ${HOST_IP_NIC}
external_signaling_address = ${HOST_IP_NIC}
local_net = ${LOCAL_NET}

[9999]
type = endpoint
context = extensiones-test
disallow = all
allow = ulaw
auth = 9999
aors = 9999
direct_media = no
rtp_symmetric = yes
force_rport = yes
rewrite_contact = yes
ice_support = no
media_use_received_transport = no

[9999]
type = auth
auth_type = userpass
username = 9999
password = ${PASS_EXTENSIONS_TEST}

[9999]
type = aor
max_contacts = 2
remove_existing = yes

